# --- Database ---
DATABASE_URL="postgresql://nq:nq@localhost:5432/novelquick?schema=public"

# --- Redis (queue + cache + danmaku pubsub) ---
REDIS_URL="redis://localhost:6379"

# --- Better Auth ---
BETTER_AUTH_SECRET="dev-secret-change-me"
BETTER_AUTH_URL="http://localhost:3000"

# --- URLs ---
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# --- Video storage ---
# local | s3
VIDEO_STORAGE_DRIVER="local"
VIDEO_LOCAL_DIR="./storage/videos"
VIDEO_PUBLIC_BASE_URL="http://localhost:3000/api/media"

# S3-compatible (R2 / MinIO) — only used when VIDEO_STORAGE_DRIVER=s3
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"

# --- FFmpeg ---
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
